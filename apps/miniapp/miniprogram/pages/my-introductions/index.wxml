<view class="container">
  <view class="card">
    <view class="row">
      <view style="font-weight: 600;">{{i18n["intro.mineTitle"]}}</view>
      <button size="mini" bindtap="onTapRefresh">{{i18n["common.refresh"]}}</button>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{!loading && items.length === 0}}">
    <view class="muted">{{i18n["intro.empty"]}}</view>
  </view>

  <view
    class="card"
    style="margin-top: 16rpx;"
    wx:for="{{items}}"
    wx:key="id"
    data-id="{{item.requestId}}"
    bindtap="onTapItem"
  >
    <view style="font-weight: 600;">{{item.requestTitle || item.requestId}}</view>
    <view class="muted" style="margin-top: 8rpx;">{{item.requestOwnerDisplayName || item.requestOwnerId}}</view>
    <view class="muted" style="margin-top: 8rpx; white-space: pre-wrap;">{{item.note}}</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.contactChannel}}">
      {{i18n["intro.contactChannel"]}}：{{item.contactChannel}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.contactName}}">
      {{i18n["intro.contactName"]}}：{{item.contactName}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.contactTitle}}">
      {{i18n["intro.contactTitle"]}}：{{item.contactTitle}}
    </view>
    <view class="muted" style="margin-top: 8rpx; white-space: pre-wrap;" wx:if="{{item.clue}}">
      {{i18n["intro.clue"]}}：{{item.clue}}
    </view>
    <view class="muted" style="margin-top: 8rpx;">
      {{item.outcome ? (item.outcome === 'success' ? i18n['request.resolveSuccess'] : i18n['request.resolveFail']) : "-"}}
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{!loading && items.length > 0 && !hasMore}}">
    <view class="muted">{{i18n["common.noMore"]}}</view>
  </view>
</view>
