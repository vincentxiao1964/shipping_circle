<view class="container">
  <view class="card">
    <view style="font-weight: 600;">{{i18n["request.editTitle"]}}</view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="muted">{{i18n["request.title"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{title}}"
      bindinput="onInputTitle"
      placeholder="{{i18n['request.title']}}"
    />
    <view class="muted" style="margin-top: 12rpx;">{{i18n["request.companyName"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{companyName}}"
      bindinput="onInputCompanyName"
      bindblur="onBlurCompanyName"
      placeholder="{{i18n['request.companyName']}}"
    />
    <view class="card" style="margin-top: 12rpx;" wx:if="{{companySuggestVisible && companySuggestItems.length > 0}}">
      <view class="muted" style="margin-bottom: 8rpx;">{{i18n["request.companySuggest"]}}</view>
      <view
        class="row"
        style="padding: 12rpx 0;"
        wx:for="{{companySuggestItems}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        catchtap="onTapSelectCompany"
      >
        <view style="font-weight: 600;">{{item.name}}</view>
        <view class="muted" style="font-size: 24rpx;" wx:if="{{item.region}}">{{item.region}}</view>
      </view>
    </view>
    <view class="muted" style="margin-top: 12rpx;">{{i18n["request.tags"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{tagsInput}}"
      bindinput="onInputTags"
      placeholder="{{i18n['request.tags']}}"
    />
    <button size="mini" style="margin-top: 12rpx;" bindtap="onTapPickTags">
      {{i18n["request.tagsPick"]}}
    </button>
    <view class="muted" style="margin-top: 12rpx;" wx:if="{{businesses.length > 0}}">
      <block wx:for="{{businesses}}" wx:for-item="b" wx:key="*this">
        <button size="mini" style="margin-right: 12rpx; margin-top: 8rpx;" data-business="{{b}}" catchtap="onTapRemoveBusiness">
          {{b}} ×
        </button>
      </block>
    </view>
    <view class="muted" style="margin-top: 12rpx;">{{i18n["request.content"]}}</view>
    <textarea
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx; min-height: 240rpx;"
      value="{{content}}"
      bindinput="onInputContent"
      placeholder="{{i18n['request.content']}}"
    />
    <button type="primary" style="margin-top: 16rpx;" bindtap="onTapSave">
      {{i18n["request.save"]}}
    </button>
  </view>
</view>
