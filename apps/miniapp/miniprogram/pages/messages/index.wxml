<view class="container">
  <view class="card">
    <view class="row">
      <view style="font-weight: 600;">{{i18n["messages.title"]}}</view>
      <view>
        <button size="mini" bindtap="onTapRefresh">{{i18n["common.refresh"]}}</button>
        <button size="mini" style="margin-left: 12rpx;" bindtap="onTapMarkAllRead">
          {{i18n["messages.markAllRead"]}}
        </button>
      </view>
    </view>
  </view>

  <view
    class="card"
    style="margin-top: 16rpx;"
    wx:for="{{items}}"
    wx:key="id"
    data-id="{{item.id}}"
    data-type="{{item.type}}"
    data-post-id="{{item.postId}}"
    data-from-user-id="{{item.fromUserId}}"
    data-request-id="{{item.requestId}}"
    data-intro-id="{{item.introId}}"
    bindtap="onTapItem"
  >
    <view class="row">
      <view style="font-weight: 600;">
        {{item.typeLabel}}
      </view>
      <view class="muted" style="font-size: 24rpx;">
        {{item.readLabel}}
      </view>
    </view>
    <view style="margin-top: 8rpx;">{{item.title}}</view>
    <view class="muted" style="margin-top: 8rpx; white-space: pre-wrap;">{{item.content}}</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.type === 'requestPing' && item.companyName}}">
      {{i18n["messages.company"]}}：{{item.companyName}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.type === 'requestPing' && item.tagsText}}">
      {{i18n["messages.tags"]}}：{{item.tagsText}}
    </view>
    <view class="row" style="margin-top: 12rpx;" wx:if="{{item.type === 'requestPing'}}">
      <button size="mini" data-request-id="{{item.requestId}}" catchtap="onTapOpenRequest">{{i18n["messages.openRequest"]}}</button>
      <button
        size="mini"
        style="margin-left: 12rpx;"
        data-request-id="{{item.requestId}}"
        catchtap="onTapQuickIntroduce"
        wx:if="{{item.canQuickIntroduce}}"
      >
        {{i18n["messages.introduceNow"]}}
      </button>
      <button size="mini" style="margin-left: 12rpx;" data-request-id="{{item.requestId}}" catchtap="onTapClaimNow">
        {{i18n["messages.claimNow"]}}
      </button>
    </view>
    <view class="row" style="margin-top: 12rpx;" wx:if="{{item.isNormalizeReport}}">
      <button size="mini" data-keys="{{item.normalizeKeysParam}}" catchtap="onTapOpenAdmin">{{i18n["messages.openAdmin"]}}</button>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{!loading && items.length === 0}}">
    <view class="muted">{{i18n["messages.empty"]}}</view>
  </view>
</view>
