<view class="container">
  <view class="card">
    <view class="row">
      <view>
        <view style="font-weight: 600;">{{i18n["home.title"]}}</view>
        <view class="muted" style="margin-top: 8rpx;">{{i18n["home.subtitle"]}}</view>
      </view>
      <view>
        <button size="mini" bindtap="onTapRefresh">
          {{i18n["common.refresh"]}}
        </button>
        <button size="mini" bindtap="onTapSearch">
          {{i18n["company.searchTitle"]}}
        </button>
        <button size="mini" type="primary" style="margin-left: 12rpx;" bindtap="onTapCreateRequest">
          {{i18n["request.create"]}}
        </button>
      </view>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="row">
      <button size="mini" type="{{tab === 'square' ? 'primary' : 'default'}}" bindtap="onTapTabSquare">
        {{i18n["home.tab.square"]}}
      </button>
      <button size="mini" type="{{tab === 'mine' ? 'primary' : 'default'}}" bindtap="onTapTabMine">
        {{i18n["home.tab.mine"]}}
      </button>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{tab === 'square'}}">
    <view class="row">
      <button size="mini" type="{{tag ? 'default' : 'primary'}}" bindtap="onTapFilterAll">
        {{i18n["home.filter.all"]}}
      </button>
      <button size="mini" type="{{tag ? 'primary' : 'default'}}" bindtap="onTapFilterTag">
        {{i18n["home.filter.tag"]}} {{tag ? '(' + tag + ')' : ''}}
      </button>
    </view>
  </view>

  <view
    class="card"
    style="margin-top: 16rpx;"
    wx:for="{{items}}"
    wx:key="id"
    data-id="{{item.id}}"
    bindtap="onTapItem"
  >
    <view style="font-weight: 600;">{{item.title}}</view>
    <view class="muted" style="margin-top: 8rpx;">
      {{item.content}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.companyName}}">
      {{item.companyName}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.tags && item.tags.length > 0}}">
      {{item.tags.join(", ")}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.priceHint}}">
      {{i18n["request.priceHint"]}}：{{formatMoneyRange(item.priceHint)}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.status === 'closed'}}">
      {{i18n["request.closed"]}}
    </view>
    <view class="muted" style="margin-top: 12rpx;">
      {{item.introCount}} {{i18n["request.introCount"]}}
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{!loading && items.length === 0}}">
    <view class="muted">{{i18n["request.empty"]}}</view>
  </view>

  <view class="card" style="margin-top: 16rpx;" wx:if="{{!loading && items.length > 0 && !hasMore}}">
    <view class="muted">{{i18n["common.noMore"]}}</view>
  </view>
</view>
