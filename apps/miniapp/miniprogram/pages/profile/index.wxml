<view class="container">
  <view class="card">
    <view style="font-weight: 600;">{{i18n["me.title"]}}</view>
    <view class="muted" style="margin-top: 8rpx;">{{i18n["me.subtitle"]}}</view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="row">
      <view>
        <view style="font-weight: 600;">{{i18n["me.userId"]}}</view>
        <view class="muted" style="margin-top: 8rpx;">
          {{userId || "-"}}
        </view>
      </view>
      <button size="mini" type="{{isAuthed ? 'default' : 'primary'}}" bindtap="onTapAuth">
        {{isAuthed ? i18n["me.logout"] : i18n["me.login"]}}
      </button>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="row">
      <view style="font-weight: 600;">{{i18n["me.points"]}}</view>
      <view style="font-weight: 600;">{{points}}</view>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <view class="muted">{{i18n["me.introSuccess"]}}</view>
      <view>{{introSuccessCount}}</view>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <view class="muted">{{i18n["me.introFail"]}}</view>
      <view>{{introFailCount}}</view>
    </view>
    <view class="muted" style="margin-top: 12rpx;">
      {{i18n["me.skills"]}}：
      <block wx:if="{{topTags.length > 0}}">
        <block wx:for="{{topTags}}" wx:key="tag">
          {{item.tag}}({{item.count}})
        </block>
      </block>
      <block wx:else>-</block>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["me.apiBaseUrl"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{apiBaseUrlInput}}"
      bindinput="onInputApiBaseUrl"
      placeholder="{{i18n['me.apiBaseUrlHint']}}"
    />
    <button size="mini" type="primary" style="margin-top: 12rpx;" bindtap="onTapSaveApiBaseUrl">
      {{i18n["me.save"]}}
    </button>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["me.displayName"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{displayNameInput}}"
      bindinput="onInputDisplayName"
      placeholder="{{i18n['me.displayNameHint']}}"
    />
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["me.company"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{companyName}}"
      bindinput="onInputCompanyName"
      bindblur="onBlurCompanyName"
      placeholder="{{i18n['me.companyHint']}}"
    />
    <view class="card" style="margin-top: 12rpx;" wx:if="{{companySuggestVisible && companySuggestItems.length > 0}}">
      <view
        class="row"
        style="padding: 12rpx 0;"
        wx:for="{{companySuggestItems}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        catchtap="onTapSelectCompany"
      >
        <view style="font-weight: 600;">{{item.name}}</view>
        <view class="muted" style="font-size: 24rpx;" wx:if="{{item.region}}">{{item.region}}</view>
      </view>
    </view>
    <view style="font-weight: 600; margin-top: 16rpx;">{{i18n["me.businesses"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{businessesInput}}"
      bindinput="onInputBusinesses"
      placeholder="{{i18n['me.businessesHint']}}"
    />
    <view style="font-weight: 600; margin-top: 16rpx;">{{i18n["me.titleLabel"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{titleInput}}"
      bindinput="onInputTitle"
      placeholder="{{i18n['me.titleHint']}}"
    />
    <view style="font-weight: 600; margin-top: 16rpx;">{{i18n["me.contactChannel"]}}</view>
    <input
      style="margin-top: 12rpx; padding: 16rpx; border: 1px solid #eeeeee; border-radius: 12rpx;"
      value="{{contactChannelInput}}"
      bindinput="onInputContactChannel"
      placeholder="{{i18n['me.contactChannelHint']}}"
    />
    <view class="row" style="margin-top: 16rpx;">
      <view>
        <view style="font-weight: 600;">{{i18n["me.visibility"]}}</view>
        <view class="muted" style="margin-top: 8rpx;">{{contactVisibilityText}}</view>
      </view>
      <button size="mini" bindtap="onTapPickVisibility">{{i18n["me.save"]}}</button>
    </view>
    <button size="mini" type="primary" style="margin-top: 12rpx;" bindtap="onTapSaveProfile">
      {{i18n["me.saveProfile"]}}
    </button>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="row">
      <view>
        <view style="font-weight: 600;">{{i18n["me.language"]}}</view>
        <view class="muted" style="margin-top: 8rpx;">
          {{currentLanguageText}}
        </view>
      </view>
      <button size="mini" bindtap="onTapSwitchLanguage">
        {{i18n["me.switchLanguage"]}}
      </button>
    </view>
  </view>
</view>
