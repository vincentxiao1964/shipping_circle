<view class="container">
  <view class="card">
    <view style="font-weight: 600;">{{i18n["login.title"]}}</view>
    <view class="muted" style="margin-top: 8rpx;">{{i18n["login.tip"]}}</view>
  </view>

  <button type="primary" style="margin-top: 16rpx;" bindtap="onTapWeChatLogin">
    {{i18n["login.wechat"]}}
  </button>

  <view class="muted" style="margin-top: 16rpx;" wx:if="{{statusText}}">
    {{statusText}}
  </view>
</view>
