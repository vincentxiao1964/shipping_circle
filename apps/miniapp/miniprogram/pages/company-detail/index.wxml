<view class="container" wx:if="{{item}}">
  <view class="card">
    <view class="row">
      <view style="font-weight: 600;">{{item.name}}</view>
      <view>
        <button size="mini" bindtap="onTapRefresh">{{i18n["common.refresh"]}}</button>
        <button size="mini" style="margin-left: 12rpx;" bindtap="onTapAddAlias">{{i18n["company.addAlias"]}}</button>
        <button size="mini" style="margin-left: 12rpx;" bindtap="onTapManageContacts">{{i18n["contact.manage"]}}</button>
        <button
          size="mini"
          type="{{item.followedByMe ? 'default' : 'primary'}}"
          style="margin-left: 12rpx;"
          bindtap="onTapToggleFollow"
        >
          {{item.followedByMe ? i18n["company.unfollow"] : i18n["company.follow"]}}
        </button>
      </view>
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.region}}">{{item.region}}</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.followersText}}">
      {{item.followersText}}
    </view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.tags && item.tags.length > 0}}">
      {{i18n["company.tags"]}}：{{item.tags.join(", ")}}
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["company.roles"]}} ({{item.roles.length}})</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{item.roles.length === 0}}">-</view>

    <view class="card" style="margin-top: 16rpx;" wx:for="{{item.roles}}" wx:for-item="r" wx:key="business">
      <view class="row">
        <view style="font-weight: 600;">{{r.business}}</view>
        <view class="muted">{{r.title}}</view>
      </view>
      <button
        size="mini"
        type="primary"
        style="margin-top: 12rpx;"
        data-business="{{r.business}}"
        bindtap="onTapCreateRequest"
      >
        {{i18n["company.createRequest"]}}
      </button>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["contact.sectionTitle"]}}</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{!contactLoading && contactGroups.length === 0}}">
      {{i18n["contact.empty"]}}
    </view>
    <view
      class="card"
      style="margin-top: 16rpx;"
      wx:for="{{contactGroups}}"
      wx:for-item="g"
      wx:key="business"
    >
      <view style="font-weight: 600;">{{g.business}}</view>
      <view class="muted" style="margin-top: 8rpx;" wx:if="{{!g.contacts || g.contacts.length === 0}}">-</view>
      <view class="card" style="margin-top: 12rpx;" wx:for="{{g.contacts}}" wx:for-item="c" wx:key="id">
        <view class="row">
          <view style="font-weight: 600;">{{c.contactName || "-"}}</view>
          <button size="mini" data-channel="{{c.contactChannel}}" catchtap="onTapCopyContact">{{i18n["contact.copy"]}}</button>
        </view>
        <view class="muted" style="margin-top: 8rpx;" wx:if="{{c.status === 'stale'}}">{{i18n["contact.stale"]}}</view>
        <view class="muted" style="margin-top: 8rpx;" wx:if="{{c.status === 'candidate'}}">{{i18n["contact.candidate"]}}</view>
        <view class="row" style="margin-top: 8rpx;" wx:if="{{c.status === 'stale' || c.status === 'candidate'}}">
          <button size="mini" type="primary" data-id="{{c.id}}" catchtap="onTapContactConfirm">{{i18n["contact.confirm"]}}</button>
          <button size="mini" style="margin-left: 12rpx;" data-id="{{c.id}}" data-channel="{{c.contactChannel}}" catchtap="onTapContactUpdate">
            {{i18n["contact.update"]}}
          </button>
          <button size="mini" style="margin-left: 12rpx;" data-id="{{c.id}}" catchtap="onTapContactInvalid">{{i18n["contact.markInvalid"]}}</button>
        </view>
        <view class="muted" style="margin-top: 8rpx;" wx:if="{{c.contactTitle}}">{{c.contactTitle}}</view>
        <view class="muted" style="margin-top: 8rpx;" wx:if="{{c.clue}}">{{c.clue}}</view>
      </view>
    </view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view style="font-weight: 600;">{{i18n["company.relatedRequests"]}} ({{related.length}})</view>
    <view class="muted" style="margin-top: 8rpx;" wx:if="{{related.length === 0}}">-</view>
    <view
      class="card"
      style="margin-top: 16rpx;"
      wx:for="{{related}}"
      wx:for-item="req"
      wx:key="id"
      data-id="{{req.id}}"
      bindtap="onTapRequest"
    >
      <view style="font-weight: 600;">{{req.title}}</view>
      <view class="muted" style="margin-top: 8rpx;">{{req.tags && req.tags.length > 0 ? req.tags.join(", ") : ""}}</view>
    </view>
  </view>
</view>

<view class="container" wx:else>
  <view class="card">
    <view class="muted">{{i18n["common.notFound"]}}</view>
  </view>
</view>
